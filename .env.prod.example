# Chorus Messenger — Production Environment Variables
# Copy this to .env.prod and fill in your values.
# These will be loaded by Dokploy at deploy time.

# ─── Database ──────────────────────────────────────────────
DB_PASSWORD=ChangeMe123

# ─── JWT Secret (REQUIRED — generate a strong random key) ──
# Generate with: openssl rand -base64 64
JWT_SECRET=your-very-long-random-secret-at-least-64-chars

# ─── Google Translate API (optional) ──────────────────────
# Leave empty to use mock translations
GOOGLE_TRANSLATE_API_KEY=

# ─── Appwrite (optional) ──────────────────────────────────
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=
VITE_APPWRITE_ENDPOINT=
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_DATABASE_ID=
VITE_APPWRITE_CLIENT_API_KEY=
