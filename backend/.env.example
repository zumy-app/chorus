# Environment
ENVIRONMENT=development

# Database
DATABASE_URL=postgres://messenger:password@localhost:5432/messenger_dev?sslmode=disable

# Redis
REDIS_URL=localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production-use-long-random-string

# Google Translate API (optional - app works without it using mock translations)
GOOGLE_TRANSLATE_API_KEY=

# =============================================================================
# Translation Provider Configuration
# =============================================================================
# Choose which translation backend to use: "openai", "ollama", or "translator-engine"
# - "openai": Uses any OpenAI-compatible API (OpenRouter, OpenCode Go, OpenAI, Codex, etc.)
# - "ollama": Uses a local Ollama instance
# - "translator-engine": Uses the legacy llama.cpp translator engine
TRANSLATION_PROVIDER=openai

# OpenAI-compatible provider settings (used when TRANSLATION_PROVIDER=openai)
# Set OPENAI_API_KEY to your API key (OpenCode Go, OpenRouter, OpenAI, etc.)
OPENAI_BASE_URL=https://api.opencode.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama settings (used when TRANSLATION_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Translator Engine (llama.cpp with ALMA-7B GGUF, used when TRANSLATION_PROVIDER=translator-engine)
TRANSLATOR_ENGINE_URL=http://localhost:5002

# Server
PORT=8080